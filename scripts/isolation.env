# Defaults for isolation scripts (user-level directory layout).
# Override before running: export VAR=value  or  VAR=value sudo -E ./script.sh
#
# DATA_ROOT        Root for per-user dirs and shared (e.g. /data, /data/shared)
# SHARED_GROUP     Group for read-only shared datasets
# SHARED_MODE      Octal mode for /data/shared (2775 setgid or 0750 per doc)
# DEFAULT_LOGIN_SHELL  Default login shell for new users (overridable by --shell)
# USER_UMASK_HINT  umask written to new users' ~/.bashrc when applicable
# USER_DATA_PREFIX Prefix for per-user data dir name (before username)
# USER_DATA_SUFFIX Suffix for per-user data dir name (after username)
# DRY_RUN          Set to 1 to print commands without executing
# ISOLATION_BASHRC_MARK  Marker line before umask block in ~/.bashrc

: "${DATA_ROOT:=/data}"
: "${SHARED_GROUP:=shared_ro}"
: "${SHARED_MODE:=2775}"
: "${DEFAULT_LOGIN_SHELL:=/bin/bash}"
: "${USER_UMASK_HINT:=027}"
: "${USER_DATA_PREFIX:=}"
: "${USER_DATA_SUFFIX:=_data}"
: "${DRY_RUN:=0}"
: "${ISOLATION_BASHRC_MARK:=# isolation (main.typ)}"
