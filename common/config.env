# Central defaults for isolation and default-user-environment scripts.
# Override before running: export VAR=value  or  VAR=value sudo -E ./script.sh
#
# DATA_ROOT             Root for per-user dirs and shared data (e.g. /data)
# SHARED_DATA_DIR_NAME  Directory under DATA_ROOT for shared datasets (default shared_data -> .../shared_data)
# SHARED_DATA_PATH      Full path (default ${DATA_ROOT}/${SHARED_DATA_DIR_NAME}; override for a fixed absolute path)
# SHARED_GROUP          Group for shared datasets (e.g. shared_ro)
# SHARED_DATA_MODE      Octal mode for SHARED_DATA_PATH (pairs with SHARED_SOFTWARE_MODE)
# DEFAULT_LOGIN_SHELL   Default login shell for new users (overridable by --shell)
# USER_UMASK_HINT       umask written to new users' ~/.bashrc when applicable
# USER_DATA_PREFIX      Prefix for per-user data dir name (before username)
# USER_DATA_SUFFIX      Suffix for per-user data dir name (after username)
# USER_HOME_MODE        Octal chmod for /home/<user> after useradd (isolation/add-isolation-user.sh)
# USER_DATA_DIR_MODE    Octal chmod for DATA_ROOT/<prefix><user><suffix> (private data dir)
# USER_DATA_ROOT_LINK_NAME  Symlink in $HOME -> DATA_ROOT (e.g. data)
# ENABLE_DATA_ROOT_LINK     Set 0 to skip ~/USER_DATA_ROOT_LINK_NAME
# SOFTWARE_ROOT, SOFTWARE_GROUP, SHARED_SOFTWARE_MODE  Shared collaborative software tree (default root ${DATA_ROOT}/shared_software)
# USER_SOFTWARE_LINK_NAME, ENABLE_SOFTWARE_AREA  Per-user link into shared software
# TEMPLATE_DIR          Directory for apply-default-user-environment templates
# DRY_RUN               Set to 1 to print commands without executing
# ISOLATION_BASHRC_MARK Marker line before umask block in ~/.bashrc
# ISOLATION_ROOTLESS_DOCKER_MARK  Marker before rootless Docker env (no systemd user session)

_COMMON_CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_REPO_ROOT="$(cd "${_COMMON_CONFIG_DIR}/.." && pwd)"

: "${DATA_ROOT:=/data}"
: "${SHARED_DATA_DIR_NAME:=shared_data}"
: "${SHARED_DATA_PATH:=${DATA_ROOT}/${SHARED_DATA_DIR_NAME}}"
: "${SHARED_GROUP:=shared_ro}"
: "${SHARED_DATA_MODE:=3775}"
: "${DEFAULT_LOGIN_SHELL:=/bin/bash}"
: "${USER_UMASK_HINT:=027}"
: "${USER_DATA_PREFIX:=}"
: "${USER_DATA_SUFFIX:=_data}"
: "${USER_HOME_MODE:=700}"
: "${USER_DATA_DIR_MODE:=700}"
: "${DRY_RUN:=0}"
: "${ISOLATION_BASHRC_MARK:=# isolation (main.typ)}"
: "${ISOLATION_ROOTLESS_DOCKER_MARK:=# isolation: rootless docker env}"

: "${SOFTWARE_ROOT:=${DATA_ROOT}/shared_software}"
: "${SOFTWARE_GROUP:=software}"
: "${SHARED_SOFTWARE_MODE:=3775}"
: "${USER_SOFTWARE_LINK_NAME:=shared_software}"
: "${USER_DATA_ROOT_LINK_NAME:=data}"
: "${ENABLE_DATA_ROOT_LINK:=1}"
: "${TEMPLATE_DIR:=${_REPO_ROOT}/template}"
: "${ENABLE_SOFTWARE_AREA:=1}"
