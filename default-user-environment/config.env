# Extends isolation/isolation.env for doc/default.typ (collaborative software + templates).
# Sourced by common.sh; override via environment before sudo -E.

_DUE_CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../isolation/isolation.env
source "${_DUE_CONFIG_DIR}/../isolation/isolation.env"

_REPO_ROOT="$(cd "${_DUE_CONFIG_DIR}/.." && pwd)"

: "${SOFTWARE_ROOT:=/data/shared_software}"
: "${SOFTWARE_GROUP:=software}"
: "${SOFTWARE_MODE:=3775}"
: "${USER_SOFTWARE_LINK_NAME:=software}"
: "${TEMPLATE_DIR:=${_REPO_ROOT}/template}"
: "${ENABLE_SOFTWARE_AREA:=1}"
